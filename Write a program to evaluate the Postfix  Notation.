#include <stdio.h>
#include <ctype.h>
#include <math.h>

#define MAX 100

int stack[MAX];
int top = -1;

// Push function
void push(int value) {
    stack[++top] = value;
}

// Pop function
int pop() {
    return stack[top--];
}

int main() {
    char postfix[MAX];
    int i, a, b, result;

    printf("Enter postfix expression: ");
    scanf("%s", postfix);

    for(i = 0; postfix[i] != '\0'; i++) {
        
        // If operand (digit)
        if(isdigit(postfix[i])) {
            push(postfix[i] - '0');  // Convert char to int
        }
        else {
            // Operator
            b = pop();
            a = pop();

            switch(postfix[i]) {
                case '+': push(a + b); break;
                case '-': push(a - b); break;
                case '*': push(a * b); break;
                case '/': push(a / b); break;
                case '^': push(pow(a, b)); break;
            }
        }
    }

    result = pop();
    printf("Result = %d\n", result);

    return 0;
}
